{
	"name": "angular-extended-builder",
	"version": "22.0.0",
	"description": "Angular extended builders with custom options for esbuild and Vite",
	"keywords": [
		"angular",
		"angular-builder",
		"builder",
		"esbuild",
		"vite"
	],
	"license": "MIT",
	"contributors": [
		{
			"email": "11534760+muuvmuuv@users.noreply.github.com",
			"name": "Marvin Heilemann"
		}
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/muuvmuuv/angular-extended-builders.git",
		"directory": "projects/angular-extended-builder"
	},
	"files": [
		"dist",
		"builders.json"
	],
	"type": "commonjs",
	"sideEffects": false,
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"typings": "./dist/index.d.ts",
	"scripts": {
		"watch": "tsc --watch",
		"build": "cp ../../README.md README.md && del-cli dist/ && tsc -p tsconfig.prod.json && node schemes.mjs",
		"test": "vitest run",
		"test:watch": "vitest",
		"ng": "ng"
	},
	"dependencies": {
		"tslib": "^2.8.1",
		"tsx": "^4.21.0"
	},
	"devDependencies": {
		"@angular/build": "^22.0.4",
		"@angular/compiler": "^22.0.3",
		"@angular/compiler-cli": "^22.0.3",
		"ng-packagr": "^22.0.0",
		"typescript": "6.0.3"
	},
	"peerDependencies": {
		"@angular-devkit/architect": "^0.2200.0",
		"@angular-devkit/core": "^22.0.0",
		"@angular/cli": "^22.0.0",
		"rxjs": "^7.8.1"
	},
	"engines": {
		"node": ">=24"
	},
	"builders": "builders.json"
}
